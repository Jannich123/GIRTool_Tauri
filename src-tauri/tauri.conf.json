{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GIRTool",
  "version": "0.1.0",
  "identifier": "com.girtool.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GIRTool",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "GIRTool",
    "copyright": "© 2024 GIRTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/GIRTool_Column_Reference.xlsx", "resources/AGENTS.md", "resources/ai_rag_index.json"],
    "windows": {
      "wix": {
        "language": "en-US",
        "upgradeCode": "F78BF8E8-87BB-4F94-8EB4-3D1429C0110D"
      },
      "nsis": {
        "installerHooks": "nsis/hooks.nsh",
        "installMode": "perMachine",
        "startMenuFolder": "GIRTool",
        "languages": ["English"]
      }
    }
  },
  "plugins": {
    "shell": { "open": true }
  }
}
