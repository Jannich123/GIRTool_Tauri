{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability — grants all GIRTool commands and plugin access to the main window.",
  "windows": ["main", "popout-*"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "core:app:default",
    "core:path:default",
    "core:resources:default",

    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",

    "opener:default",
    "opener:allow-open-path",
    "opener:allow-open-url",

    "shell:default",
    "shell:allow-open"
  ]
}
